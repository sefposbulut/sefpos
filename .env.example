# Supabase Configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key_here

# Sıralı sayım belgesi (SAYIM-00001): önce Supabase'te migration `20260514193000_stock_count_batches`, sonra build'de:
# VITE_STOCK_COUNT_BATCH_RPC=true
# (Kapalıyken SYM- referansı kullanılır; /rpc/create_stock_count_batch çağrılmaz → 404 olmaz.)

# Partner webhook URL'leri (Getir, Yemeksepeti, online-order-webhook) Ayarlar ekranında gösterilir.
# Cloudflare Pages'te `functions/api/supabase-fn` proxy kullanıyorsanız (www.sefpos.com.tr → Supabase Edge):
# VITE_PUBLIC_SUPABASE_FN_PROXY_BASE_URL=https://www.sefpos.com.tr/api/supabase-fn
# Cloudflare ortam değişkeni: SEFPOS_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co (proxy hedefi)
# Yönlendirme `functions/api/supabase-fn/` dosya tabanlı rotadadır; `public/_routes.json` kullanmayın
# (sürükle-bırak / bazı Pages yükleme yollarında "not supported" hatası verir).
# Pages'te build kökü repo kökü, çıktı dist olmalı (functions/ klasörü repoda kökte kalsın).
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=your_database_password

# Opsiyonel: npm run db:migrate-remote — Session pooler URI (şifrede +, @, # varsa URL-encode edin).
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Edge Functions (Supabase Dashboard → Edge Functions → Secrets; .env’de degil)
# OZTEK_KULLANICINO=...
# OZTEK_KULLANICIADI=...
# OZTEK_SIFRE=...
# OZTEK_ORGINATOR=AYKA SOFT
# OTP_SIGNING_SECRET=...  (opsiyonel; varsayilan zayif)

# Demo User (for testing)
# Email: info@sefpos.com.tr
# Password: 2128948++

# Database Mode (sqlserver, postgres, local)
# VITE_DB_MODE=postgres

# Telefon → Sentetik Auth E-posta Domain'i (varsayılan: sefpos.com.tr)
# ÖNEMLİ: Supabase GoTrue, MX kaydı olmayan domain'leri "invalid email" olarak reddeder.
# Eğer "Email address ... is invalid" hatası alıyorsanız:
#   a) Bu domain'in MX kaydını ekleyin (Cloudflare DNS panel),
#   b) Veya MX kaydı olan başka bir domain'e değiştirin (örn. sefpos.app, mail.firma.com).
# VITE_PHONE_AUTH_EMAIL_DOMAIN=sefpos.com.tr

# QR menü: ürün görseli yoksa otomatik yemek görseli (Pollinations; dış servis). Kapatmak için:
# VITE_QR_MENU_AI_PLACEHOLDER_IMAGES=0
